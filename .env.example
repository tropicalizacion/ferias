# Copy to .env and fill in values before running docker compose.
# Required for both dev and prod unless noted otherwise.

# Django settings
# Generate a fresh SECRET_KEY per environment; never reuse dev keys in prod.
# e.g.: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DEBUG=
# Canonical apex hostname and www variant. SITE_DOMAIN / SITE_DOMAIN_WWW
# must live in .env (project root) because compose.prod.yml interpolates
# them into Traefik labels. .env.prod only overrides application-level
# flags.
SITE_DOMAIN=
SITE_DOMAIN_WWW=
ALLOWED_HOSTS=
WAGTAILADMIN_BASE_URL=

# Database settings
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Host machine ports
# WEB_PORT is only consumed by compose.dev.yml (production does NOT
# publish the container port — Traefik reaches it over traefik_proxy).
WEB_PORT=8000
DATABASE_PORT=5432

# External services
GOOGLE_MAPS_API_KEY=
